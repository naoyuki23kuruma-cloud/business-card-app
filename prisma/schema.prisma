generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Card {
  id               String    @id @default(uuid())
  imageUrl         String?
  thumbnailUrl     String?
  rawOcrText       String?
  name             String?
  nameKana         String?
  company          String?
  department       String?
  title            String?
  email            String?
  phone            String?
  mobile           String?
  fax              String?
  address          String?
  postalCode       String?
  website          String?
  exchangeDate     DateTime?
  exchangeLocation String?
  memo             String?
  tags             String    @default("[]")
  isFavorite       Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([name])
  @@index([company])
  @@index([isFavorite])
  @@map("cards")
}
